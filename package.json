{
  "name": "bajaclaw",
  "version": "0.20.2",
  "description": "BajaClaw - autonomous agents on your terms",
  "type": "module",
  "bajaclaw": {
    "npmName": "bajaclaw",
    "updateUrl": "https://raw.githubusercontent.com/backyarddd/BajaClaw/main/package.json"
  },
  "bin": {
    "create-bajaclaw": "bin/create-bajaclaw.js",
    "bajaclaw": "bin/bajaclaw.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static.js",
    "dev": "tsx src/cli.ts",
    "dashboard:dev": "tsx watch src/cli.ts dashboard",
    "test": "node scripts/run-tests.js",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    "skills/",
    "templates/"
  ],
  "keywords": [
    "claude",
    "agent",
    "autonomous",
    "mcp",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.0",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ora": "^8.1.0",
    "react": "^19.2.5",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "discord.js": "^14.16.0",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/node-telegram-bot-api": "^0.64.10",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
